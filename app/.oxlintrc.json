{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react", "unicorn", "import"],
  "jsPlugins": ["eslint-plugin-boundaries"],
  "env": {
    "builtin": true
  },
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "error",
    "style": "error"
  },
  "options": {
    "typeAware": true
  },
  "settings": {
    "import/resolver": {
      "typescript": true,
      "node": true
    },
    "boundaries/elements": [
      { "type": "app-root", "pattern": "src/app.tsx", "mode": "file" },
      { "type": "app-root", "pattern": "src/main.tsx", "mode": "file" },
      { "type": "app-root", "pattern": "src/features/shell" },
      {
        "type": "feature",
        "pattern": "src/features/*",
        "capture": ["featureName"]
      },
      { "type": "shared", "pattern": "src/shared" }
    ]
  },
  "rules": {
    "typescript/no-floating-promises": [
      "error",
      { "ignoreVoid": true, "ignoreIIFE": true }
    ],
    "typescript/no-misused-promises": [
      "error",
      { "checksVoidReturn": { "attributes": false } }
    ],

    "react/exhaustive-deps": "off",
    "react/react-in-jsx-scope": "off",
    "react/jsx-max-depth": "off",
    "react/jsx-props-no-spreading": "off",
    "react/jsx-handler-names": "off",
    "unicorn/no-null": "off",
    "unicorn/no-array-callback-reference": "off",
    "unicorn/prefer-global-this": "off",
    "import/no-named-export": "off",
    "import/group-exports": "off",
    "import/consistent-type-specifier-style": "off",
    "import/exports-last": "off",
    "import/prefer-default-export": "off",
    "import/first": "off",
    "import/no-nodejs-modules": "off",
    "import/no-namespace": "off",
    "import/no-unassigned-import": "off",
    "typescript/consistent-type-definitions": "off",
    "typescript/parameter-properties": "off",
    "unbound-method": "off",
    "no-misused-spread": "off",
    "no-unsafe-type-assertion": "off",
    "no-magic-numbers": "off",
    "func-style": "off",
    "sort-keys": "off",
    "no-ternary": "off",
    "sort-imports": "off",
    "max-statements": "off",
    "id-length": "off",
    "curly": "off",
    "capitalized-comments": "off",
    "no-continue": "off",
    "max-params": "off",
    "prefer-destructuring": "off",
    "init-declarations": "off",
    "no-implicit-coercion": "off",
    "consistent-return": "off",
    "no-shadow": "off",
    "no-await-in-loop": "off",
    "no-nested-ternary": "off",
    "unicorn/prefer-add-event-listener": "off",
    "typescript/no-unnecessary-type-conversion": "off",
    "boundaries/dependencies": [
      "error",
      {
        "default": "disallow",
        "rules": [
          {
            "from": { "type": "app-root" },
            "allow": { "to": { "type": "*" } }
          },
          {
            "from": { "type": "shared" },
            "allow": { "to": { "type": "shared" } }
          },
          {
            "from": { "type": "feature" },
            "allow": {
              "to": [
                {
                  "type": "feature",
                  "captured": { "featureName": "{{ featureName }}" }
                },
                { "type": "shared" },
                { "type": "app-root" }
              ]
            }
          }
        ]
      }
    ]
  },
  "ignorePatterns": [
    "dist/**",
    "node_modules/**",
    "coverage/**",
    "src-tauri/**",
    "scripts/**"
  ],
  "overrides": []
}
