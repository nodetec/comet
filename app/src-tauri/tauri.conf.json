{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "comet",
  "version": "0.0.0-alpha",
  "identifier": "md.comet-alpha",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "comet",
        "acceptFirstMouse": true,
        "decorations": true,
        "visible": false,
        "width": 1200,
        "height": 600,
        "minWidth": 710,
        "minHeight": 370,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 18,
          "y": 24
        }
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/accounts/**/attachments/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
