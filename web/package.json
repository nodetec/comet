{
  "name": "@comet/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3100",
    "generate-routes": "node ./scripts/generate-routes.mjs",
    "build": "pnpm run generate-routes && vite build",
    "start": "node .output/server/index.mjs",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/",
    "typecheck": "pnpm run generate-routes && tsc --noEmit"
  },
  "dependencies": {
    "@comet/data": "workspace:*",
    "@fontsource-variable/geist": "^5.2.8",
    "@noble/ciphers": "^2.1.1",
    "@tanstack/react-query": "^5.90.0",
    "@tanstack/react-router": "^1.167.5",
    "@tanstack/react-router-ssr-query": "^1.166.9",
    "@tanstack/react-start": "^1.166.18",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "lucide-react": "^0.475.0",
    "nostr-tools": "^2.23.3",
    "postgres": "^3.4.7",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.4",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/router-cli": "1.166.13",
    "@tanstack/router-generator": "1.166.13",
    "@types/node": "^22.5.4",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "nitro": "3.0.260311-beta",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "oxlint-tsgolint": "^0.20.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.3",
    "vite": "^8.0.1"
  },
  "turbo": {
    "tasks": {
      "build": {
        "outputs": [
          ".output/**"
        ]
      }
    }
  }
}
