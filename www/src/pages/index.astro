  <style>
    .shooting-star {
      position: absolute;
      height: 4px;
      background: linear-gradient(-45deg, white, transparent);
      border-radius: 999px;
      filter: drop-shadow(0 0 6px rgba(150, 180, 255, 0.6));
      transform: rotate(45deg);
      transform-origin: top left;
      animation-name: tail, shooting;
      animation-timing-function: ease-in-out;
      animation-iteration-count: infinite;
    }

    .shooting-star:nth-child(1) { top: 10%; left: 10%; animation-delay: 1s; animation-duration: 10s; }
    .shooting-star:nth-child(2) { top: 5%; left: 45%; animation-delay: 5s; animation-duration: 14s; }
    .shooting-star:nth-child(3) { top: 18%; left: 20%; animation-delay: 8s; animation-duration: 12s; }

    @keyframes tail {
      0% { width: 0; opacity: 0; }
      30% { width: 150px; opacity: 0.75; }
      70% { opacity: 0.75; }
      100% { width: 0; opacity: 0; }
    }

    @keyframes shooting {
      0% { transform: translate(0) rotate(45deg); }
      100% { transform: translate(300px, 300px) rotate(45deg); }
    }
  </style>

  <script>
    const canvas = document.getElementById("stars-canvas") as HTMLCanvasElement;
    const ctx = canvas.getContext("2d")!;

    function resize() {
      canvas.width = canvas.offsetWidth * devicePixelRatio;
      canvas.height = canvas.offsetHeight * devicePixelRatio;
      ctx.scale(devicePixelRatio, devicePixelRatio);
    }

    interface Star {
      x: number;
      y: number;
      r: number;
      alpha: number;
      speed: number;
      phase: number;
    }

    let stars: Star[] = [];
    const STAR_COUNT = 300;

    function createStars() {
      const w = canvas.offsetWidth;
      const h = canvas.offsetHeight;
      stars = [];
      for (let i = 0; i < STAR_COUNT; i++) {
        stars.push({
          x: Math.random() * w,
          y: Math.random() * h,
          r: Math.random() * 1.4 + 0.3,
          alpha: Math.random() * 0.6 + 0.2,
          speed: Math.random() * 0.8 + 0.2,
          phase: Math.random() * Math.PI * 2,
        });
      }
    }

    function draw(t: number) {
      const w = canvas.offsetWidth;
      const h = canvas.offsetHeight;
      ctx.clearRect(0, 0, w, h);

      for (const s of stars) {
        const twinkle = Math.sin(t * 0.001 * s.speed + s.phase) * 0.3 + 0.7;
        const a = s.alpha * twinkle;
        ctx.beginPath();
        ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255, 255, 255, ${a})`;
        ctx.fill();

        // Subtle glow on brighter stars
        if (s.r > 1) {
          ctx.beginPath();
          ctx.arc(s.x, s.y, s.r * 2.5, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(180, 200, 255, ${a * 0.15})`;
          ctx.fill();
        }
      }

      requestAnimationFrame(draw);
    }

    resize();
    createStars();
    requestAnimationFrame(draw);

    window.addEventListener("resize", () => {
      resize();
      createStars();
    });
  </script>
