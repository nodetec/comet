{
  "name": "comet",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "scripts": {
    "dev": "turbo run dev --filter=@comet/app",
    "bundle": "pnpm tauri build --bundles app",
    "prepare": "husky",
    "typecheck": "turbo run typecheck",
    "build": "turbo run build --filter=@comet/app",
    "lint": "turbo run lint",
    "lint:fix": "pnpm --filter @comet/app lint:fix",
    "test": "turbo run test --filter=@comet/app",
    "blossom:build": "pnpm --filter @comet/blossom build",
    "blossom:dev": "pnpm --filter @comet/blossom dev",
    "blossom:lint": "pnpm --filter @comet/blossom lint",
    "blossom:lint:fix": "pnpm --filter @comet/blossom lint:fix",
    "blossom:test": "pnpm --filter @comet/blossom test",
    "blossom:typecheck": "pnpm --filter @comet/blossom typecheck",
    "mcp:dev": "pnpm --filter @comet/mcp dev",
    "mcp:start": "pnpm --filter @comet/mcp start",
    "mcp:build": "pnpm --filter @comet/mcp build",
    "mcp:lint": "pnpm --filter @comet/mcp lint",
    "mcp:lint:fix": "pnpm --filter @comet/mcp lint:fix",
    "mcp:test": "pnpm --filter @comet/mcp test",
    "mcp:typecheck": "pnpm --filter @comet/mcp typecheck",
    "relay:build": "pnpm --filter @comet/relay build",
    "relay:dev": "pnpm --filter @comet/relay dev",
    "relay:lint": "pnpm --filter @comet/relay lint",
    "relay:lint:fix": "pnpm --filter @comet/relay lint:fix",
    "relay:test": "pnpm --filter @comet/relay test",
    "relay:typecheck": "pnpm --filter @comet/relay typecheck",
    "web:dev": "pnpm --filter @comet/web dev",
    "web:build": "pnpm --filter @comet/web build",
    "web:typecheck": "pnpm --filter @comet/web typecheck",
    "web:lint": "pnpm --filter @comet/web lint",
    "web:lint:fix": "pnpm --filter @comet/web lint:fix",
    "www:dev": "pnpm --filter @comet/www dev",
    "www:build": "pnpm --filter @comet/www build",
    "www:preview": "pnpm --filter @comet/www preview",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "turbo run preview --filter=@comet/app",
    "seed:db": "pnpm --filter @comet/app seed:db",
    "tauri": "pnpm --filter @comet/app tauri",
    "tauri:dev": "pnpm --filter @comet/app tauri:dev"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.0.0"
  },
  "lint-staged": {
    "app/**/*.{ts,tsx}": [
      "pnpm --filter @comet/app exec eslint --fix",
      "prettier --write"
    ],
    "relay/**/*.{ts,tsx}": [
      "pnpm --filter @comet/relay exec eslint --fix",
      "prettier --write"
    ],
    "blossom/**/*.{ts,tsx}": [
      "pnpm --filter @comet/blossom exec eslint --fix",
      "prettier --write"
    ],
    "mcp/**/*.{ts,tsx}": [
      "pnpm --filter @comet/mcp exec eslint --fix",
      "prettier --write"
    ],
    "web/**/*.{ts,tsx}": [
      "pnpm --filter @comet/web exec eslint --fix",
      "prettier --write"
    ],
    "packages/data/**/*.{ts,tsx}": [
      "pnpm --filter @comet/data exec eslint --fix",
      "prettier --write"
    ],
    "packages/nostr/**/*.{ts,tsx}": [
      "pnpm --filter @comet/nostr exec eslint --fix",
      "prettier --write"
    ],
    "**/*.{js,mjs,cjs,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "app/**/*.{css,html}": [
      "prettier --write"
    ]
  }
}
